# =============================================================================
# Kouroukan - Variables d'environnement pour Coolify
# =============================================================================
# Copier ce fichier dans Coolify > Project > Environment Variables
# NE PAS committer ce fichier avec de vraies valeurs !
# =============================================================================

# --- Base de données PostgreSQL ---
DB_USER=kouroukan
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=kouroukan
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=kouroukan;Username=kouroukan;Password=CHANGE_ME_STRONG_PASSWORD

# --- JWT Authentication ---
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_SECRET_KEY
JWT_ISSUER=kouroukan.gn
JWT_AUDIENCE=kouroukan-app

# --- RabbitMQ ---
RABBITMQ_USER=kouroukan
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD

# --- MinIO (stockage fichiers) ---
MINIO_ACCESS_KEY=kouroukan
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY

# --- Frontend ---
API_BASE_URL=https://api.kouroukan.dianora.org

# --- Ollama IA (optionnel - laisser vide pour désactiver) ---
OLLAMA_BASE_URL=
OLLAMA_MODEL=mistral
