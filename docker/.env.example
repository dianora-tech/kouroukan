# =============================================================================
# Kouroukan - Variables d'environnement
# =============================================================================
# INSTRUCTIONS :
#   1. Copier ce fichier : cp .env.example .env
#   2. Remplir TOUTES les valeurs marquees "CHANGE_ME"
#   3. Ne JAMAIS commiter le fichier .env dans Git
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL 16
# -----------------------------------------------------------------------------
DB_USER=kouroukan
DB_PASSWORD=CHANGE_ME
DB_NAME=kouroukan
DB_PORT=5432
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=kouroukan;Username=kouroukan;Password=CHANGE_ME

# -----------------------------------------------------------------------------
# Securite JWT
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_LONG_SECRET_KEY
JWT_ISSUER=kouroukan.gn
JWT_AUDIENCE=kouroukan-app

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_USER=kouroukan
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_MGMT_PORT=15672

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Pas de mot de passe par defaut en dev. En production, configurer requirepass.

# -----------------------------------------------------------------------------
# MinIO (Stockage fichiers S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=kouroukan
MINIO_SECRET_KEY=CHANGE_ME_MINIMUM_8_CHARACTERS
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Ollama (IA generative - module support)
# -----------------------------------------------------------------------------
OLLAMA_MODEL=mistral
OLLAMA_PORT=11434

# -----------------------------------------------------------------------------
# Uptime Kuma (Monitoring)
# -----------------------------------------------------------------------------
UPTIME_KUMA_PORT=3001
