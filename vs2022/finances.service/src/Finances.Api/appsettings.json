{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:5005",

  "Jwt": {
    "Issuer": "kouroukan-gateway",
    "Audience": "kouroukan-services",
    "Key": "CHANGE_ME_IN_PRODUCTION_USE_256_BITS_KEY_AT_LEAST"
  },

  "GnDapper": {
    "ConnectionString": "Host=localhost;Port=5432;Database=kouroukan;Username=kouroukan_app;Password=CHANGE_ME",
    "DefaultSchema": "finances",
    "CommandTimeout": 30,
    "EnableSensitiveDataLogging": false
  },

  "GnMessaging": {
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "Username": "kouroukan",
      "Password": "CHANGE_ME",
      "VirtualHost": "/",
      "Exchange": "kouroukan.events",
      "ExchangeType": "topic"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} | {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
