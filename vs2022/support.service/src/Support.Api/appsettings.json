{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "GnDapper": {
    "ConnectionString": "Host=postgres;Port=5432;Database=kouroukan;Username=kouroukan;Password=${POSTGRES_PASSWORD};Search Path=support",
    "CommandTimeoutSeconds": 30,
    "EnableSqlInjectionGuard": true
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "kouroukan",
    "Audience": "kouroukan-clients"
  },
  "RabbitMq": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "kouroukan",
    "Password": "${RABBITMQ_PASSWORD}",
    "VirtualHost": "/",
    "Exchange": "kouroukan.events"
  },
  "Ollama": {
    "BaseUrl": "http://ollama:11434",
    "Model": "mistral",
    "MaxTokens": 2048,
    "Temperature": 0.3,
    "SystemPrompt": "Tu es un assistant d'aide pour la plateforme Kouroukan, une plateforme de gestion scolaire en Guinee. Reponds en francais de maniere claire et concise. Utilise le contexte des articles d'aide fournis pour repondre aux questions."
  },
  "Urls": "http://+:5011"
}
